{
    "manifest_version": 3,
    "name": "Vortext",
    "version": "1.0",
    "description": "Find subtitles on any video.",
    "action": {
        "default_popup": "popup/index.html",
        "default_title": "Vortext"
    },
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://api.opensubtitles.com/*",
        "https://dl.opensubtitles.com/*"
    ]
}